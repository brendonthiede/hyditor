{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hyditor",
  "version": "0.1.0",
  "identifier": "com.brendonthiede.hyditor",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.github.com https://github.com https://127.0.0.1:* https://objects.githubusercontent.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; frame-src 'self' http://127.0.0.1:*;"
    },
    "windows": [
      {
        "title": "Hyditor",
        "width": 1400,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/brendonthiede/hyditor/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDOEY0NDA2MjE4NDIwRjAKUldUd0lJUWhCa1NQelAyK0VCWjF3bUkxVnRWMnp0M1JXcjU0UWFtRjY3SDVOQksrMTBiY3ZlWlgK"
    }
  }
}
